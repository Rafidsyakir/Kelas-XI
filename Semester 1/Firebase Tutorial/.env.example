# Environment Variables untuk Firebase App Distribution
# Copy file ini menjadi .env dan isi dengan kredensial Anda

# Firebase Token (dapatkan dengan: firebase login:ci)
FIREBASE_TOKEN=1//0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Keystore Credentials
KEYSTORE_PASSWORD=your-store-password
KEY_ALIAS=my-release-key
KEY_PASSWORD=your-key-password
