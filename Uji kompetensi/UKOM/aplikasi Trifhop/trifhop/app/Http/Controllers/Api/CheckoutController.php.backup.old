<?php

namespace App\Http\Controllers\Api;

use App\Http\Controllers\Controller;
use App\Models\Transaction;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;

class CheckoutController extends Controller
{
    /**
     * 🔧 DEEP SURGERY: Enhanced checkout controller with specific error messages
     */
    public function checkout(Request $request)
    {
        $validated = $request->validate([
            'order_id' => 'required|integer|exists:transactions,id',
        ]);

        $order = Transaction::where('id', $validated['order_id'])
            ->where('user_id', $request->user()->id)
            ->first();

        if (!$order) {
            return response()->json([
                'success' => false,
                'message' => 'Order tidak ditemukan',
                'error' => 'Order dengan ID ' . $validated['order_id'] . ' tidak ada untuk user ini',
            ], 404);
        }

        try {
            // === Validasi data yang WAJIB ada sebelum memanggil Xendit ===
            $userEmail = $request->user()->email;
            if (empty($userEmail)) {
                return response()->json([
                    'success' => false,
                    'message' => 'Email pengguna tidak tersedia',
                    'error' => 'User email kosong - tidak bisa membuat invoice',
                    'debug' => config('app.debug') ? 'User email is empty' : null,
                ], 422);
            }

            $totalPrice = (int) $order->total_price;
            if ($totalPrice <= 0) {
                return response()->json([
                    'success' => false,
                    'message' => 'Total harga tidak valid',
                    'error' => "Total harga harus lebih dari 0. Nilai saat ini: $totalPrice",
                    'debug' => config('app.debug') ? "Amount must be greater than 0, got: {$totalPrice}" : null,
                ], 422);
            }

            $xenditSecret = (string) config('services.xendit.secret_key');
            $xenditMode = (string) config('services.xendit.mode', 'sandbox');
            $isDemoMode = env('XENDIT_DEMO_MODE', false);

            if (empty($xenditSecret)) {
                return response()->json([
                    'success' => false,
                    'message' => 'Konfigurasi Xendit tidak lengkap',
                    'error' => 'XENDIT_SECRET_KEY tidak dikonfigurasi di .env',
                    'debug' => config('app.debug') ? 'XENDIT_SECRET_KEY not configured' : null,
                ], 500);
            }

            // ✅ DEMO MODE: Untuk testing tanpa need valid Xendit API key
            if ($isDemoMode || str_contains($xenditSecret, 'DEMO_')) {
                $externalId = 'TRIFHOP-ORDER-' . $order->id . '-' . time();
                $demoInvoiceUrl = url('/api/payment/' . $externalId);
                
                $order->update([
                    'payment_status' => 'PENDING',
                    'xendit_invoice_id' => 'demo_' . $externalId,
                    'xendit_external_id' => $externalId,
                    'xendit_invoice_url' => $demoInvoiceUrl,
                ]);

                \Log::info('✅ Demo mode checkout created', [
                    'order_id' => $order->id,
                    'external_id' => $externalId,
                    'amount' => $totalPrice,
                    'user_email' => $userEmail,
                ]);

                return response()->json([
                    'success' => true,
                    'message' => 'Invoice pembayaran demo berhasil dibuat',
                    'data' => [
                        'order_id' => $order->id,
                        'external_id' => $externalId,
                        'amount' => (float) $order->total_price,
                        'payer_email' => (string) $request->user()->email,
                        'description' => 'Pembayaran Trifhop (Demo Mode)',
                        'invoice_id' => 'demo_' . $externalId,
                        'invoice_url' => $demoInvoiceUrl,
                        'invoice_status' => 'PENDING',
                        'mode' => 'demo',
                    ],
                ]);
            }

            Configuration::setXenditKey($xenditSecret);
            $invoiceApi = new InvoiceApi();

            // Idempotency: jika invoice sudah ada, gunakan invoice yang sama agar tidak dobel.
            if (!empty($order->xendit_invoice_id)) {
                try {
                    $existingInvoice = $invoiceApi->getInvoiceById((string) $order->xendit_invoice_id);
                    $existingStatus = strtoupper((string) $existingInvoice->getStatus());

                    $this->updateOrderPaymentFromInvoiceStatus($order, $existingStatus);
                    $order->refresh();

                    return response()->json([
                        'success' => true,
                        'message' => 'Invoice Xendit sudah tersedia',
                        'data' => [
                            'order_id' => $order->id,
                            'external_id' => $order->xendit_external_id,
                            'amount' => (float) $order->total_price,
                            'payer_email' => (string) $request->user()->email,
                            'description' => 'Pembayaran Trifhop',
                            'invoice_id' => (string) $existingInvoice->getId(),
                            'invoice_url' => (string) ($existingInvoice->getInvoiceUrl() ?? $order->xendit_invoice_url),
                            'invoice_status' => $existingStatus,
                            'mode' => $xenditMode,
                        ],
                    ]);
                } catch (\Throwable $e) {
                    // Jika invoice lama tidak ditemukan, lanjutkan buat yang baru
                    \Log::warning('❌ Failed to get existing invoice from Xendit', [
                        'invoice_id' => $order->xendit_invoice_id,
                        'error_message' => $e->getMessage(),
                        'error_type' => get_class($e),
                    ]);
                    $order->update(['xendit_invoice_id' => null]);
                }
            }

            $externalId = 'TRIFHOP-ORDER-' . $order->id . '-' . time();

            // Payload dengan format yang benar untuk Xendit API
            $payload = [
                'external_id' => $externalId,
                'amount' => $totalPrice, // HARUS integer untuk IDR
                'payer_email' => $userEmail,
                'description' => 'Pembayaran Trifhop - Order #' . $order->id,
                'currency' => 'IDR',
                'success_redirect_url' => (string) config('services.xendit.success_redirect_url', 'https://trifhop.local/payment-success'),
                'failure_redirect_url' => (string) config('services.xendit.failure_redirect_url', 'https://trifhop.local/payment-failed'),
            ];

            \Log::info('📤 Creating Xendit invoice with payload:', $payload);

            $invoice = $invoiceApi->createInvoice($payload);

            $order->update([
                'payment_status' => 'PENDING',
                'xendit_invoice_id' => $invoice->getId(),
                'xendit_external_id' => $externalId,
                'xendit_invoice_url' => $invoice->getInvoiceUrl(),
            ]);

            \Log::info('✅ Invoice Xendit berhasil dibuat', [
                'order_id' => $order->id,
                'invoice_id' => $invoice->getId(),
                'amount' => $totalPrice,
            ]);

            return response()->json([
                'success' => true,
                'message' => 'Invoice Xendit berhasil dibuat',
                'data' => [
                    'order_id' => $order->id,
                    'external_id' => $externalId,
                    'amount' => (float) $order->total_price,
                    'payer_email' => (string) $request->user()->email,
                    'description' => 'Pembayaran Trifhop',
                    'invoice_id' => $invoice->getId(),
                    'invoice_url' => $invoice->getInvoiceUrl(),
                    'invoice_status' => $invoice->getStatus(),
                    'mode' => $xenditMode,
                ],
            ]);
        } catch (\Xendit\Exceptions\XenditSdkException $e) {
            // 🔧 DEEP SURGERY: Error khusus dari Xendit SDK - return specific message
            $statusCode = $e->getCode() ?: 500;
            $errorMessage = $e->getMessage();
            
            \Log::error('❌ Xendit SDK Error during checkout', [
                'code' => $statusCode,
                'message' => $errorMessage,
                'xendit_key_preview' => substr((string) config('services.xendit.secret_key'), 0, 20) . '...',
                'order_id' => $request->order_id ?? null,
            ]);

            // 🔧 DEEP SURGERY: Jika API key invalid, beri saran yang spesifik
            if (str_contains($errorMessage, 'API key') || str_contains($errorMessage, 'authentication') || str_contains($errorMessage, '401')) {
                return response()->json([
                    'success' => false,
                    'message' => 'API key Xendit tidak valid atau kadaluarsa',
                    'error' => 'Gagal autentikasi dengan Xendit. ' . $errorMessage,
                    'debug' => config('app.debug') ? [
                        'suggestion' => 'Update XENDIT_SECRET_KEY dengan secret key dari https://dashboard.xendit.co',
                        'key_preview' => substr((string) config('services.xendit.secret_key'), 0, 20) . '...',
                    ] : null,
                ], 401);
            }

            // 🔧 DEEP SURGERY: Jika error rate limit atau sandbox balance
            if (str_contains($errorMessage, 'rate') || str_contains($errorMessage, 'limit')) {
                return response()->json([
                    'success' => false,
                    'message' => 'Xendit rate limit terlampaui',
                    'error' => 'Terlalu banyak permintaan ke Xendit. Silakan coba lagi beberapa saat.',
                ], 429);
            }

            // 🔧 DEEP SURGERY: Return error asli dari Xendit (bukan generic message)
            return response()->json([
                'success' => false,
                'message' => $this->formatXenditErrorMessage($errorMessage),
                'error'   => $errorMessage,
                'xendit_error_code' => $statusCode,
                'debug' => config('app.debug') ? [
                    'exception_class' => get_class($e),
                    'trace' => $e->getTraceAsString(),
                ] : null,
            ], $statusCode >= 400 ? $statusCode : 500);
        } catch (\Throwable $e) {
            // 🔧 DEEP SURGERY: Generic error - return specific message dari exception
            \Log::error('❌ Checkout error (Deep Surgery logging)', [
                'message' => $e->getMessage(),
                'file' => $e->getFile(),
                'line' => $e->getLine(),
                'class' => get_class($e),
                'trace' => $e->getTraceAsString(),
                'order_id' => $request->order_id ?? null,
            ]);

            // 🔧 DEEP SURGERY: Extract meaningful error dari exception message
            $specificError = $this->extractCheckoutError($e->getMessage());

            return response()->json([
                'success' => false,
                'message' => $specificError['user_message'],
                'error'   => $e->getMessage(),
                'error_type' => $specificError['type'],
                'debug' => config('app.debug') ? [
                    'exception_class' => get_class($e),
                    'file' => $e->getFile(),
                    'line' => $e->getLine(),
                ] : null,
            ], 500);
        }
    }

    /**
     * 🔧 DEEP SURGERY: Format Xendit error message untuk user
     */
    private function formatXenditErrorMessage(string $xenditError): string
    {
        return match (true) {
            str_contains($xenditError, 'sandbox') => 'Saldo Sandbox Xendit mungkin habis. Gunakan test account yang valid.',
            str_contains($xenditError, 'invalid') => 'Data invoice tidak valid. Periksa email atau jumlah pembayaran.',
            str_contains($xenditError, 'Email') => 'Format email tidak valid',
            str_contains($xenditError, 'amount') => 'Jumlah pembayaran tidak valid',
            default => 'Gagal membuat invoice di Xendit: ' . $xenditError,
        };
    }

    /**
     * 🔧 DEEP SURGERY: Extract specific checkout error
     */
    private function extractCheckoutError(string $errorMessage): array
    {
        if (str_contains($errorMessage, 'Email')) {
            return [
                'type' => 'INVALID_EMAIL',
                'user_message' => 'Email pengguna tidak valid: ' . $errorMessage,
            ];
        }

        if (str_contains($errorMessage, 'amount') || str_contains($errorMessage, 'price')) {
            return [
                'type' => 'INVALID_AMOUNT',
                'user_message' => 'Jumlah pembayaran tidak valid: ' . $errorMessage,
            ];
        }

        if (str_contains($errorMessage, 'Database') || str_contains($errorMessage, 'database')) {
            return [
                'type' => 'DATABASE_ERROR',
                'user_message' => 'Gagal menyimpan data invoice. Silakan coba lagi.',
            ];
        }

        return [
            'type' => 'UNKNOWN_ERROR',
            'user_message' => $errorMessage,
        ];
    }

    /**
     * Payment webhook dari Xendit
     */
    public function webhook(Request $request)
    {
        $callbackToken = (string) config('services.xendit.callback_token');
        $incomingToken = (string) $request->header('x-callback-token', '');

        if ($callbackToken === '') {
            return response()->json([
                'success' => false,
                'message' => 'XENDIT_CALLBACK_TOKEN belum dikonfigurasi',
            ], 500);
        }

        if (!hash_equals($callbackToken, $incomingToken)) {
            return response()->json([
                'success' => false,
                'message' => 'Unauthorized webhook call',
            ], 401);
        }

        $externalId = (string) $request->input('external_id', '');
        $invoiceId = (string) $request->input('id', '');
        $status = strtoupper((string) $request->input('status', ''));

        if ($externalId === '' && $invoiceId === '') {
            return response()->json([
                'success' => false,
                'message' => 'Payload webhook tidak valid',
            ], 422);
        }

        $orderQuery = Transaction::query();

        if ($externalId !== '') {
            $orderQuery->where('xendit_external_id', $externalId);
        } else {
            $orderQuery->where('xendit_invoice_id', $invoiceId);
        }

        $order = $orderQuery->first();

        if (!$order) {
            return response()->json([
                'success' => false,
                'message' => 'Order tidak ditemukan',
            ], 404);
        }

        DB::transaction(function () use ($order, $status): void {
            $this->updateOrderPaymentFromInvoiceStatus($order, $status);
        });

        return response()->json([
            'success' => true,
            'message' => 'Webhook diterima',
        ]);
    }

    /**
     * Check payment status untuk order tertentu
     */
    public function checkPaymentStatus(Request $request, int $orderId)
    {
        $order = Transaction::where('id', $orderId)
            ->where('user_id', $request->user()->id)
            ->first();

        if (!$order) {
            return response()->json([
                'success' => false,
                'message' => 'Order tidak ditemukan',
            ], 404);
        }

        if (!$order->xendit_invoice_id) {
            return response()->json([
                'success' => false,
                'message' => 'Invoice Xendit belum dibuat untuk order ini',
            ], 422);
        }

        try {
            Configuration::setXenditKey((string) config('services.xendit.secret_key'));
            $invoiceApi = new InvoiceApi();

            $invoice = $invoiceApi->getInvoiceById((string) $order->xendit_invoice_id);
            $status = strtoupper((string) $invoice->getStatus());

            $this->updateOrderPaymentFromInvoiceStatus($order, $status);
            $order->refresh();

            return response()->json([
                'success' => true,
                'message' => 'Payment status checked',
                'data' => [
                    'order' => $order,
                    'invoice_status' => $status,
                    'payment_status' => $order->payment_status,
                ],
            ]);
        } catch (\Throwable $e) {
            \Log::error('Failed to check payment status', [
                'order_id' => $orderId,
                'error' => $e->getMessage(),
            ]);

            return response()->json([
                'success' => false,
                'message' => 'Gagal memeriksa status pembayaran',
                'error' => $e->getMessage(),
            ], 500);
        }
    }

    /**
     * Helper: Update order payment status dari Xendit invoice status
     */
    private function updateOrderPaymentFromInvoiceStatus(Transaction $order, string $invoiceStatus): void
    {
        $paymentStatus = match (strtoupper($invoiceStatus)) {
            'PAID', 'SETTLED' => 'PAID',
            'EXPIRED' => 'EXPIRED',
            'FAILED' => 'FAILED',
            default => 'PENDING',
        };

        $order->update([
            'payment_status' => $paymentStatus,
            'paid_at' => $paymentStatus === 'PAID' ? now() : null,
        ]);

        if ($paymentStatus === 'PAID') {
            $order->update(['status' => 'packed']);
        }
    }
}
